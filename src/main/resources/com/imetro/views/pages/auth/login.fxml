<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>


<VBox xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.imetro.ui.controller.LoginController"
      spacing="12" styleClass="card">
   <padding>
      <Insets top="18" right="18" bottom="18" left="18" />
   </padding>

   <Label text="Entrar" styleClass="h1" />
   <Label text="Escolhe o teu perfil e entra no sistema (MVP)." wrapText="true" styleClass="muted" />

   <TextField fx:id="usernameField" promptText="Email ou utilizador" />
   <PasswordField fx:id="passwordField" promptText="Palavra-passe" />
   <ComboBox fx:id="roleCombo" promptText="Perfil (Candidato/Orientador)" />

   <Label fx:id="statusLabel" text="" styleClass="muted" />
   <Button text="Entrar" onAction="#onLogin" styleClass="btn-primary" maxWidth="1.7976931348623157E308" />
</VBox>
